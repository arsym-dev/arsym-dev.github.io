    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run local",
            "type": "f5anything",
            "request": "launch",
            "command": "bundle exec jekyll serve --baseurl=\"\""
        },
        {
            "name": "Create thumbnails",
            "type": "node-terminal",
            "request": "launch",
            "command": "python create_thumbnails.py",
            "cwd": "${workspaceFolder}/uploads/"
        },
        {
            "name": "Create thumbnails (overwrite)",
            "type": "node-terminal",
            "request": "launch",
            "command": "python create_thumbnails.py --overwrite",
            "cwd": "${workspaceFolder}/uploads/"
        }
    ]
}